{
  "name": "rhizome",
  "version": "1.0.0",
  "description": "Self-hostable, page-based outliner with daily notes and Roam-style references — a fork of Tendril.",
  "type": "commonjs",
  "main": "server.js",
  "scripts": {
    "start": "node server.js",
    "lint": "eslint server.js db.js ops.js opsdoc.js cryptobox.js public/icons.js public/app.js public/app2.js public/pages.js bench",
    "typecheck": "tsc --noEmit",
    "test:db": "node tests/test-db.js",
    "test:converge": "node tests/test-converge.js",
    "test:ops": "node tests/test-ops-server.js",
    "test:optrash": "node tests/test-optrash.js",
    "test:undo": "node tests/test-undo.js",
    "test:emit": "node tests/test-emit.js",
    "test:rbconverge": "node tests/test-rb-converge.js",
    "test:worker": "node tests/test-worker.js",
    "test:opsync": "node tests/test-opsync.js",
    "test:persist": "node tests/test-persist.js",
    "test:search": "node tests/test-search.js",
    "test:mirror": "node tests/test-mirror.js",
    "test:mirrorserver": "node tests/test-mirror-server.js",
    "test:pages": "node tests/test-pages.js",
    "test:daily": "node tests/test-daily.js",
    "test:refs": "node tests/test-refs.js",
    "test:mcp": "node tests/test-mcp.js",
    "test:security": "node tests/test-security.js",
    "test:quota": "node tests/test-quota.js",
    "test:files": "node tests/test-files.js",
    "test:markdown": "node tests/test-markdown.js",
    "test:markdown-fmt": "node tests/test-markdown-fmt.js",
    "bench:curve": "node --expose-gc bench/curve.js",
    "bench:profile": "node bench/profile.js",
    "bench:load": "node bench/load.js"
  },
  "engines": {
    "node": ">=22"
  },
  "license": "MIT",
  "devDependencies": {
    "@types/node": "^25.9.3",
    "eslint": "^10.4.1",
    "globals": "^17.6.0",
    "typescript": "^6.0.3"
  }
}
